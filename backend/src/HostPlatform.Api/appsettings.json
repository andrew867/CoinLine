{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=coinline;Username=coinline;Password=coinline"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Swagger": {
    "Enabled": true
  },
  "Security": {
    "Mode": "Development",
    "ApiKeys": [],
    "GlobalRequestsPerMinutePerIp": 0
  },
  "Observability": {
    "MetricsEnabled": true,
    "MetricsPath": "/metrics"
  },
  "Platform": {
    "Seed": {
      "EnableDemoData": true
    },
    "PayloadStorage": {
      "RootPath": "",
      "RequireHealthyWhenConfigured": true
    },
    "QueryLimits": {
      "MaxPageSize": 200,
      "DefaultAuditPageSize": 50,
      "MaxAuditUnpagedTake": 500
    },
    "WorkerHeartbeat": {
      "RequireFreshHeartbeat": false,
      "MaxStaleSeconds": 300
    },
    "Retention": {
      "TelemetryEnabled": false,
      "AllowDestructiveRawPayloadTrim": false,
      "RawPayloadOlderThanDays": 365
    },
    "Cors": {
      "AllowedOrigins": []
    }
  },
  "JobOrchestration": {
    "MaxTransientRetries": 3,
    "TransientRetryDelayMs": 50
  },
  "CardPayments": {
    "SimulationMode": true,
    "PhysicalCardWritesDisabled": true
  },
  "Firmware": {
    "AllowLiveFlashing": false
  },
  "DlTransport": {
    "LiveDlaEnabled": false,
    "TransportKind": "simulation",
    "SerialPort": "",
    "Baud": 9600,
    "TimeoutMs": 3000,
    "MaxRetries": 10,
    "PacingMs": 10,
    "TcpHost": "127.0.0.1",
    "TcpPort": 0,
    "PipeName": "coinline-dla",
    "PreferCrcMode": false
  }
}
