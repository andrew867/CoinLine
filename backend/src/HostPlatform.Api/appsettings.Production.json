{
  "Swagger": {
    "Enabled": false
  },
  "Security": {
    "Mode": "ApiKey",
    "GlobalRequestsPerMinutePerIp": 600
  },
  "Observability": {
    "MetricsEnabled": true
  },
  "Platform": {
    "Seed": {
      "EnableDemoData": false
    },
    "Retention": {
      "TelemetryEnabled": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
