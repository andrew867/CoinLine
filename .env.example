# CoinLine Payphone Management Platform — environment examples
# Copy to `.env` or map into your orchestrator / systemd EnvironmentFile.
# .NET configuration uses `Section__Subsection__Key` naming for nested keys.

# -----------------------------------------------------------------------------
# CoinLine API keys (preferred product prefix)
# -----------------------------------------------------------------------------
# Comma-separated API keys merged into Security:ApiKeys at startup.
# Production: rotate regularly; never commit real values.
COINLINE_API_KEYS=replace-with-long-random-secret

# Legacy alias — supported for migration only (same effect as COINLINE_API_KEYS)
# HOSTPLATFORM_API_KEYS=

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Standard ASP.NET Core connection string environment variable.
ConnectionStrings__Default=Host=localhost;Port=5432;Database=coinline;Username=coinline;Password=CHANGE_ME

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# Production | Development | Testing
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# Listen URL for Kestrel (optional; launchSettings may override)
# ASPNETCORE_URLS=http://0.0.0.0:5006

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Development = relaxed dev auth; use ApiKey in production with keys above.
Security__Mode=Development
# Security__ApiKeys is usually supplied via COINLINE_API_KEYS instead of JSON.

# Global per-IP rate limit; 0 = disabled
Security__GlobalRequestsPerMinutePerIp=0

# -----------------------------------------------------------------------------
# Swagger / OpenAPI
# -----------------------------------------------------------------------------
Swagger__Enabled=true

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
Observability__MetricsEnabled=true
Observability__MetricsPath=/metrics

# -----------------------------------------------------------------------------
# Platform
# -----------------------------------------------------------------------------
# Disable for strict production (no demo tenants)
Platform__Seed__EnableDemoData=true

# Optional raw payload filesystem root; leave empty to disable
# Platform__PayloadStorage__RootPath=
Platform__PayloadStorage__RequireHealthyWhenConfigured=true

# Readiness: require fresh worker heartbeat (false in many single-node labs)
Platform__WorkerHeartbeat__RequireFreshHeartbeat=false
Platform__WorkerHeartbeat__MaxStaleSeconds=300

# Retention telemetry (non-destructive counts)
Platform__Retention__TelemetryEnabled=false
# DANGER: only enable with operational review
Platform__Retention__AllowDestructiveRawPayloadTrim=false
Platform__Retention__RawPayloadOlderThanDays=365

# CORS: JSON array in config; for env use __0 syntax, e.g.:
# Platform__Cors__AllowedOrigins__0=https://console.example.com

# -----------------------------------------------------------------------------
# Card payments (simulation defaults)
# -----------------------------------------------------------------------------
CardPayments__SimulationMode=true
CardPayments__PhysicalCardWritesDisabled=true

# -----------------------------------------------------------------------------
# Firmware / field programming gates
# -----------------------------------------------------------------------------
Firmware__AllowLiveFlashing=false

# -----------------------------------------------------------------------------
# Worker (separate HostPlatform.Worker process)
# -----------------------------------------------------------------------------
# Same database as API when running worker alongside CoinLine Server.
# ConnectionStrings__Default=Host=postgres;Port=5432;Database=coinline;Username=coinline;Password=CHANGE_ME
